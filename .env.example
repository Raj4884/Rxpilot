# ──────────────────────────────────────────────
# RxPilot — Environment Configuration
# ──────────────────────────────────────────────

# Anthropic (Claude Vision) — primary extraction model
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Vision provider toggle (Phase 4: swap to qwen2vl for cost comparison)
VISION_PROVIDER=claude

# ──────────────────────────────────────────────
# Postgres + pgvector
# ──────────────────────────────────────────────
POSTGRES_USER=rxpilot
POSTGRES_PASSWORD=rxpilot_dev
POSTGRES_DB=rxpilot
DATABASE_URL=postgresql+asyncpg://rxpilot:rxpilot_dev@postgres:5432/rxpilot
DATABASE_URL_SYNC=postgresql://rxpilot:rxpilot_dev@postgres:5432/rxpilot

# ──────────────────────────────────────────────
# Langfuse — observability / tracing
# ──────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-change-me
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_HOST=http://langfuse-server:3000

# Langfuse self-hosted config (used by docker-compose)
LANGFUSE_INIT_ORG_ID=rxpilot
LANGFUSE_INIT_ORG_NAME=RxPilot
LANGFUSE_INIT_PROJECT_ID=rxpilot-main
LANGFUSE_INIT_PROJECT_NAME=RxPilot Main
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-rxpilot-dev
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-rxpilot-dev
LANGFUSE_INIT_USER_EMAIL=admin@rxpilot.dev
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=rxpilot-admin

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Upload limits
# ──────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads
